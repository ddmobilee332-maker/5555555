--- [ Section: Rainbow ] ---

MainTab:CreateSection("🌈 ระบบสีรถ (RGB)")

MainTab:CreateToggle({

   Name = "เปิด/ปิด รถสีรุ้ง (Auto)",

   CurrentValue = false,

   Flag = "RainbowToggle",

   Callback = function(Value)

      rainbowActive = Value

      task.spawn(function()

         while rainbowActive do

            local hue = (tick() * (rainbowSpeed / 10)) % 1

            local color = Color3.fromHSV(hue, 1, 1)

            pcall(function()

               game:GetService("ReplicatedStorage"):WaitForChild("RE"):WaitForChild("1Player1sCa1r"):FireServer("NoMotorColor", color)

            end)

            task.wait(0.1)

         end

      end)

   end,

})



